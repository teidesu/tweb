{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "allowJs": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "sourceMap": true,
    "removeComments": false,
    "noEmit": true,
    "isolatedModules": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    // see https://www.typescriptlang.org/docs/handbook/release-notes/typescript-3-7.html#the-usedefineforclassfields-flag-and-the-declare-property-modifier
    "useDefineForClassFields": false,
    "moduleResolution": "bundler",
    "paths": {
      "solid-transition-group": ["./src/vendor/solid-transition-group"],
      "@components/*": ["./src/components/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@stores/*": ["./src/stores/*"],
      "@lib/*": ["./src/lib/*"],
      "@appManagers/*": ["./src/lib/appManagers/*"],
      "@richTextProcessor/*": ["./src/lib/richTextProcessor/*"],
      "@environment/*": ["./src/environment/*"],
      "@customEmoji/*": ["./src/lib/customEmoji/*"],
      "@rlottie/*": ["./src/lib/rlottie/*"],
      "@config/*": ["./src/config/*"],
      "@vendor/*": ["./src/vendor/*"],
      "@layer": ["./src/layer.d.ts"],
      "@types": ["./src/types.d.ts"],
      "@/*": ["./src/*"]
    },
    "types": [
      "vite/client",
      "vitest/globals",
      "node",
      "chrome",
      "dom-webcodecs"
    ],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  /* tsc --watch (run by vite-plugin-checker in dev) must NOT recurse the .claude
     git worktrees or node_modules. With no "include", tsc sets up a recursive
     watcher on the project root; descending into .claude (40k+ dirs across ~18
     worktrees, each with its own node_modules) opens enough fs.watch handles to
     crash the dev server with "EMFILE: too many open files, watch" on macOS.
     excludeDirectories prunes those subtrees from the watcher entirely. */
  "watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "excludeDirectories": ["**/node_modules", "**/.claude", "dist", "public", "coverage"]
  },
  "exclude": [
    "node_modules",
    ".claude",
    "public",
    "dist",
    "coverage",
    "scripts",
    "src/opus-recorder",
    "src/vendor/**/*.js",
    "*.js",
    "*.cjs",
    "private",
    "tweb-design"
  ]
}
